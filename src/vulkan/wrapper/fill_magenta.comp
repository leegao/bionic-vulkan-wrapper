#version 450

// The shader will be dispatched with one invocation per pixel of the output image.
layout (local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

// --- Push Constants ---
// We use push constants to pass image parameters efficiently.
layout(push_constant) uniform PushConstants {
    // Format of the source compressed data. We'll use Vulkan enum values.
    // VK_FORMAT_BC1_RGB_UNORM_BLOCK = 131
    // VK_FORMAT_BC3_UNORM_BLOCK = 137
    uint srcFormat;

    // The dimensions of the source compressed data buffer.
    uint srcRowLength;   // Stride in pixels of the source data
    uint srcImageHeight;

    // The destination image parameters.
    int offsetx;
    int offsety;
    uint dst_width;
    uint dst_height;
} push_constants;


// --- Buffers ---
// Source buffer containing the compressed BC1/BC3 blocks.
// We read it as an array of 32-bit uints for easier bit manipulation.
layout(set = 0, binding = 0) readonly buffer SourceBuffer {
    uint data[];
} srcBuffer;

// Destination buffer for the decompressed RGBA8 data.
// We now use a raw storage buffer of uints.
// layout(set = 0, binding = 1) writeonly buffer DestinationBuffer {
//     uint data[];
// } dstBuffer;

layout(set = 0, binding = 1, rgba8) writeonly uniform imageBuffer dstBuffer;

// --- Helper functions for BC1/BC3 decompression (Granite-style) ---

// Helper to unpack 565 color (RGB565 to vec3 [0,1])
vec3 unpack_565(uint c) {
    // Extract the two 16-bit endpoint colors (RGB565 format)
    return vec3(
        float((c >> 11) & 0x1F) / 31.0,
        float((c >> 5) & 0x3F) / 63.0,
        float(c & 0x1F) / 31.0
    );
}

// Helper to unpack 8-bit alpha (uint to float [0,1])
float unpack_8bit_alpha(uint a) {
    return float(a) / 255.0;
}

// Decodes a single 64-bit BC1 (DXT1) block for a specific pixel
vec4 decode_bc1_block(uvec2 block_data, uint pixel_index_in_block) {
    uint color0_565 = block_data.x & 0xFFFF;
    uint color1_565 = (block_data.x >> 16) & 0xFFFF;
    uint indices = block_data.y;

    vec3 c0 = unpack_565(color0_565);
    vec3 c1 = unpack_565(color1_565);

    vec4 colors[4];
    colors[0] = vec4(c0, 1.0);
    colors[1] = vec4(c1, 1.0);

    if (color0_565 > color1_565) {
        colors[2] = vec4(mix(c0, c1, 1.0/3.0), 1.0);
        colors[3] = vec4(mix(c0, c1, 2.0/3.0), 1.0);
    } else {
        colors[2] = vec4(mix(c0, c1, 0.5), 1.0);
        colors[3] = vec4(0.0, 0.0, 0.0, 0.0); // Transparent
    }

    uint index = (indices >> (pixel_index_in_block * 2)) & 0x3;
    return colors[index];
}

// Decodes a single 64-bit BC3 (DXT5) alpha block for a specific pixel
float decode_bc3_alpha(uvec2 alpha_data, uint pixel_index_in_block) {
    uint alpha0 = alpha_data.x & 0xFF;
    uint alpha1 = (alpha_data.x >> 8) & 0xFF;

    // Extract 3-bit index from the 48 bits
    uint index_val;
    uint bit_offset = pixel_index_in_block * 3;

    // Handle indices spanning across the two uints (alpha_data.x and alpha_data.y)
    if (bit_offset < 32) {
        index_val = (alpha_data.x >> bit_offset) & 0x7;
    } else {
        index_val = (alpha_data.y >> (bit_offset - 32)) & 0x7;
    }

    float alpha_values[8];
    alpha_values[0] = unpack_8bit_alpha(alpha0);
    alpha_values[1] = unpack_8bit_alpha(alpha1);

    if (alpha0 > alpha1) {
        // 6 interpolated alpha values
        alpha_values[2] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 1.0/7.0)));
        alpha_values[3] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 2.0/7.0)));
        alpha_values[4] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 3.0/7.0)));
        alpha_values[5] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 4.0/7.0)));
        alpha_values[6] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 5.0/7.0)));
        alpha_values[7] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 6.0/7.0)));
    } else {
        // 4 interpolated alpha values + 0.0 and 1.0
        alpha_values[2] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 1.0/5.0)));
        alpha_values[3] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 2.0/5.0)));
        alpha_values[4] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 3.0/5.0)));
        alpha_values[5] = unpack_8bit_alpha(uint(mix(float(alpha0), float(alpha1), 4.0/5.0)));
        alpha_values[6] = 0.0; // Transparent
        alpha_values[7] = 1.0; // Opaque
    }

    return alpha_values[index_val];
}

// Decodes a single 128-bit BC3 (DXT5) block for a specific pixel
vec4 decode_bc3_block(uvec4 block_data, uint pixel_index_in_block) {
    // BC3 block: first 64 bits are alpha, last 64 bits are color (BC1)
    uvec2 alpha_part = uvec2(block_data.x, block_data.y);
    uvec2 color_part = uvec2(block_data.z, block_data.w);

    vec4 color = decode_bc1_block(color_part, pixel_index_in_block);
    float alpha = decode_bc3_alpha(alpha_part, pixel_index_in_block);

    color.a = alpha;
    return color;
}


void main() {
    // Global pixel coordinate for the output image, every pixel in the destination is matched with a worker
    ivec2 pixel_coord = ivec2(gl_GlobalInvocationID.xy);
    //ivec2 pixel_coord = ivec2(idx / 8, idx % 8);

    // Don't do anything if we are outside the target image region
    if (pixel_coord.x >= push_constants.dst_width || pixel_coord.y >= push_constants.dst_height) {
        return;
    }

    // Calculate the coordinate of the 4x4 block this pixel belongs to
    ivec2 block_coord = pixel_coord / 4;

    // Calculate the linear index of the block in the source buffer
    uint block_index = block_coord.y * (push_constants.srcRowLength / 4) + block_coord.x;

    // Find the specific pixel this thread is responsible for within its 4x4 block
    uint local_x = gl_GlobalInvocationID.x % 4;
    uint local_y = gl_GlobalInvocationID.y % 4;
    uint pixel_index_in_block = local_y * 4 + local_x;

    vec4 decompressed_color;

    // VK_FORMAT_BC1_RGB_UNORM_BLOCK = 131
    if (push_constants.srcFormat == 131) {
        // BC1 blocks are 8 bytes (2 uints)
        uint offset = block_index * 2;
        uvec2 block_data = uvec2(srcBuffer.data[offset], srcBuffer.data[offset+1]);
        decompressed_color = decode_bc1_block(block_data, pixel_index_in_block);
    }
    // VK_FORMAT_BC3_UNORM_BLOCK = 137
    else if (push_constants.srcFormat == 137) {
        // BC3 blocks are 16 bytes (4 uints)
        uint offset = block_index * 4;
        uvec4 block_data = uvec4(srcBuffer.data[offset], srcBuffer.data[offset+1], srcBuffer.data[offset+2], srcBuffer.data[offset+3]);
        decompressed_color = decode_bc3_block(block_data, pixel_index_in_block);
    } else {
        // Unsupported format, write an error color (magenta)
        decompressed_color = vec4(1.0, 0.0, 1.0, 1.0);
    }

    // Calculate the final destination coordinate including the offset
    ivec2 final_dst_coord = ivec2(push_constants.offsetx, push_constants.offsety) + pixel_coord;

    // Calculate the linear index into the destination buffer using its row length
    int dst_index = int(final_dst_coord.y * push_constants.srcRowLength + final_dst_coord.x);

    imageStore(dstBuffer, dst_index, decompressed_color);
}
