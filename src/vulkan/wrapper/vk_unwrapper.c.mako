            *out_pnext_ptr = (VkBaseOutStructure *) VK_ALLOC(VkPhysicalDeviceMapMemoryPlacedFeaturesEXT); // Set ext->pnext = vk_alloc
            unwrap_VkPhysicalDeviceMapMemoryPlacedFeaturesEXT_members_only(device, (VkPhysicalDeviceMapMemoryPlacedFeaturesEXT *)*out_pnext_ptr, (const VkPhysicalDeviceMapMemoryPlacedFeaturesEXT *)pnext);
            break;
        case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_RAW_ACCESS_CHAINS_FEATURES_NV:        
            *out_pnext_ptr = (VkBaseOutStructure *) VK_ALLOC(VkPhysicalDeviceRawAccessChainsFeaturesNV); // Set ext->pnext = vk_alloc
            unwrap_VkPhysicalDeviceRawAccessChainsFeaturesNV_members_only(device, (VkPhysicalDeviceRawAccessChainsFeaturesNV *)*out_pnext_ptr, (const VkPhysicalDeviceRawAccessChainsFeaturesNV *)pnext);
            break;
        case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_IMAGE_ALIGNMENT_CONTROL_FEATURES_MESA:        
            *out_pnext_ptr = (VkBaseOutStructure *) VK_ALLOC(VkPhysicalDeviceImageAlignmentControlFeaturesMESA); // Set ext->pnext = vk_alloc
            unwrap_VkPhysicalDeviceImageAlignmentControlFeaturesMESA_members_only(device, (VkPhysicalDeviceImageAlignmentControlFeaturesMESA *)*out_pnext_ptr, (const VkPhysicalDeviceImageAlignmentControlFeaturesMESA *)pnext);
            break;
        case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_SHADER_REPLICATED_COMPOSITES_FEATURES_EXT:        
            *out_pnext_ptr = (VkBaseOutStructure *) VK_ALLOC(VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT); // Set ext->pnext = vk_alloc
            unwrap_VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT_members_only(device, (VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT *)*out_pnext_ptr, (const VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT *)pnext);
            break;
        default:
            /* The calculate function allocated space, now we copy it. */
            memcpy(*out_pnext_ptr, pnext, vk_structure_type_size(pnext));
            break;
        }
        out_pnext_ptr = &(*out_pnext_ptr)->pNext;
    }
    *out_pnext_ptr = NULL;
}
